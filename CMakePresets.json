{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2026-x64",
      "displayName": "Visual Studio 2026 (x64)",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/vs2026-x64",
      "architecture": {
        "value": "x64"
      },
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/linux-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Universal Release (arm64 + x86_64)",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/macos-release",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Build Debug",
      "configurePreset": "vs2026-x64",
      "configuration": "Debug",
      "targets": [
        "phu-beat-sync-multi-scope_VST3"
      ]
    },
    {
      "name": "release",
      "displayName": "Build Release",
      "configurePreset": "vs2026-x64",
      "configuration": "Release",
      "targets": [
        "phu-beat-sync-multi-scope_VST3"
      ]
    },
    {
      "name": "linux-build",
      "displayName": "Linux Build",
      "configurePreset": "linux-release",
      "configuration": "Release",
      "targets": [
        "phu-beat-sync-multi-scope_VST3"
      ]
    },
    {
      "name": "macos-build",
      "displayName": "macOS Universal Build",
      "configurePreset": "macos-release",
      "configuration": "Release",
      "targets": [
        "phu-beat-sync-multi-scope_VST3",
        "phu-beat-sync-multi-scope_AU"
      ]
    }
  ]
}
